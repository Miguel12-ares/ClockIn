# Configuración de Base de Datos
DATABASE_URL=mysql+pymysql://user:user_password@db:3306/db_name

# Claves Secretas
SECRET_KEY=your_flask_secret_key_here_change_in_production
JWT_SECRET_KEY=your_jwt_secret_key_here_change_in_production

# Configuración de la Aplicación
ADMIN_MODE=true
INIT_DB_ON_START=true
FLASK_ENV=development

# Configuración de JWT (opcional, usa valores por defecto si no se especifican)
# JWT_ACCESS_TOKEN_EXPIRES=3600  # 1 hora en segundos
# JWT_REFRESH_TOKEN_EXPIRES=2592000  # 30 días en segundos
